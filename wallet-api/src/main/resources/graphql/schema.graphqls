type Wallet {
    id: ID!
    ownerName: String!
    balance: Float!
}

# Criamos um tipo de entrada específico para a criação
input WalletInput {
    ownerName: String!
}

type Query {
    getWallet(id: ID!): Wallet
    findAllWallets: [Wallet]! # Nova query de listagem
}

type Mutation {
    # Agora a mutation espera o argumento 'input' do tipo 'WalletInput'
    createWallet(input: WalletInput!): Wallet
    deleteWallet(id: ID!): Boolean! # Nova mutation de deleção
}