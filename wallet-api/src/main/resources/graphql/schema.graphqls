type Transaction {
    id: ID!
    type: String!
    amount: Float!
    timestamp: String!
}

type Wallet {
    id: ID!
    ownerName: String!
    balance: Float!
    transactions: [Transaction]!
}

input WalletInput {
    ownerName: String!
}

type Query {
    getWallet(id: ID!): Wallet
    findAllWallets: [Wallet]!
}

type Mutation {
    createWallet(input: WalletInput!): Wallet!
    deleteWallet(id: ID!): Boolean!
    depositWallet(walletId: ID!, amount: Float!): Wallet
}